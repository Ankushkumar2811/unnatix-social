# ---- Server ----
PORT=4000
APP_BASE_URL=http://localhost:4000
FRONTEND_URL=http://localhost:5173

# ---- Meta (Facebook Pages + Instagram Business) ----
# Create app at https://developers.facebook.com/apps
# Production callback: https://unnatix-social.vercel.app/auth/meta/callback
META_APP_ID=
META_APP_SECRET=
META_REDIRECT_URI=http://localhost:4000/auth/meta/callback

# ---- Google (YouTube + Google Business Profile) ----
# Create OAuth credentials at https://console.cloud.google.com
# Production callback: https://unnatix-social.vercel.app/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:4000/auth/google/callback

# ---- LinkedIn ----
# Create app at https://www.linkedin.com/developers/apps
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
LINKEDIN_REDIRECT_URI=http://localhost:4000/auth/linkedin/callback

# ---- X (Twitter) ----
# Create app at https://developer.x.com
X_CLIENT_ID=
X_CLIENT_SECRET=
X_REDIRECT_URI=http://localhost:4000/auth/x/callback

# ---- Pinterest (reserved) ----
# Create app at https://developers.pinterest.com/apps
PINTEREST_APP_ID=
PINTEREST_APP_SECRET=
PINTEREST_REDIRECT_URI=http://localhost:4000/auth/pinterest/callback
