{
  "version": 2,
  "builds": [
    {
      "src": "frontend/package.json",
      "use": "@vercel/static-build",
      "config": { "distDir": "dist" }
    },
    {
      "src": "api/index.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    { "src": "/auth/(.*)", "dest": "/api/index.js" },
    { "src": "/accounts/(.*)", "dest": "/api/index.js" },
    { "src": "/accounts", "dest": "/api/index.js" },
    { "src": "/schedule/(.*)", "dest": "/api/index.js" },
    { "src": "/schedule", "dest": "/api/index.js" },
    { "src": "/post/(.*)", "dest": "/api/index.js" },
    { "src": "/privacy-policy", "dest": "/frontend/index.html" },
    { "src": "/(.*)", "dest": "/frontend/$1" }
  ]
}
